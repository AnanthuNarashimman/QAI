{
  "name": "qai-desktop",
  "version": "1.0.0",
  "description": "QAI — Website UI & CTA Audit Tool",
  "main": "main.js",
  "scripts": {
    "start": "electron . --dev",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^8.2.0"
  },
  "devDependencies": {
    "electron": "^36.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.qai.desktop",
    "productName": "QAI",
    "copyright": "Copyright © 2025 QAI",
    "asar": true,
    "npmRebuild": false,
    "publish": null,
    "directories": {
      "output": "../dist-electron",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../qai-client/dist",
        "to": "app"
      },
      {
        "from": "resources/backend/qai-backend",
        "to": "backend",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ]
    }
  }
}
